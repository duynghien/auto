# Sao chép file này thành /opt/scripts/backup.env (hoặc <INSTALL_DIR>/backup.env) và chmod 600

# Đường dẫn chính
WEB_ROOT=/var/www
BACKUP_DIR=/backup
RETENTION_DAYS=3
MIN_FREE_GB=5
LOCK_FILE=/var/lock/wordpress-backup.lock

# Google Drive qua rclone
GDRIVE_ENABLED=true
GDRIVE_REMOTE=gdrive:backups/WORDOPS
GDRIVE_RETENTION_DAYS=7
RCLONE_CONFIG=/root/.config/rclone/rclone.conf

# Cấu hình dump DB
DB_DUMP_TIMEOUT_SECONDS=300
DB_DUMP_RETRIES=3
DB_DUMP_BACKOFF_SECONDS=10
MYSQL_USER=root
MYSQL_PASSWORD=

# Telegram
TG_ENABLED=true
TG_BOT_TOKEN=
TG_CHAT_ID=
