# ===== Mem0 OpenMemory Configuration =====

# REQUIRED — Get from https://platform.openai.com
OPENAI_API_KEY=

# Same key as OPENAI_API_KEY (used by config.json via env:API_KEY)
API_KEY=

# User ID for memory association
USER=default

# Neo4j Graph Memory
NEO4J_URI=bolt://neo4j:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=mem0_neo4j_pass

# OpenMemory UI Port (default: 3000)
UI_PORT=3000

# Next.js Settings (do not change unless you know what you're doing)
NEXT_PUBLIC_API_URL=http://localhost:8765
NEXT_PUBLIC_USER_ID=default
