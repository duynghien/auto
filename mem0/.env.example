# ===== Mem0 OpenMemory Configuration =====

# REQUIRED — Get from https://platform.openai.com
OPENAI_API_KEY=sk-xxx

# Same key as OPENAI_API_KEY (used by config.json via env:API_KEY)
API_KEY=sk-xxx

# User ID for memory association
USER=default

# Neo4j Graph Memory
NEO4J_URI=bolt://neo4j:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=mem0_neo4j_pass

# Ports (change if conflicts)
# API_PORT=8765
# UI_PORT=3000
# QDRANT_PORT=6333
# NEO4J_BROWSER_PORT=7474
# NEO4J_BOLT_PORT=7687
