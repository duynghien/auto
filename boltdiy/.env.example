# ============================================================
# bolt.diy — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your API keys.
# You only need to set the providers you want to use.
# ============================================================

# --- Application ---
PORT=5173
NODE_ENV=production
VITE_LOG_LEVEL=debug
DEFAULT_NUM_CTX=32768

# ============================================================
# AI Provider API Keys
# Enable the providers you need — leave others empty
# ============================================================

# Anthropic Claude — https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Google Gemini — https://makersuite.google.com/app/apikey
GOOGLE_GENERATIVE_AI_API_KEY=

# Groq — https://console.groq.com/keys
GROQ_API_KEY=

# OpenRouter — https://openrouter.ai/keys
OPEN_ROUTER_API_KEY=

# DeepSeek — https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=

# xAI (Grok) — https://console.x.ai/
XAI_API_KEY=

# Mistral — https://console.mistral.ai/api-keys/
MISTRAL_API_KEY=

# Together AI — https://api.together.xyz/settings/api-keys
TOGETHER_API_KEY=
TOGETHER_API_BASE_URL=

# Perplexity — https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=

# Fireworks — https://fireworks.ai/api-keys
FIREWORKS_API_KEY=

# Cohere — https://dashboard.cohere.ai/api-keys
COHERE_API_KEY=

# HuggingFace — https://huggingface.co/settings/tokens
HuggingFace_API_KEY=

# Hyperbolic — https://app.hyperbolic.xyz/settings
HYPERBOLIC_API_KEY=
HYPERBOLIC_API_BASE_URL=https://api.hyperbolic.xyz/v1/chat/completions

# Moonshot — https://platform.moonshot.ai/console/api-keys
MOONSHOT_API_KEY=

# ZhipuAI — https://open.bigmodel.cn/usercenter/apikeys
ZAI_API_KEY=

# Cerebras — https://cloud.cerebras.ai/settings
CEREBRAS_API_KEY=

# GitHub Models — https://github.com/settings/tokens
GITHUB_API_KEY=

# --- Local Models ---
# Ollama — runs on host machine (auto-detected via host.docker.internal)
OLLAMA_API_BASE_URL=http://host.docker.internal:11434

# LM Studio
LMSTUDIO_API_BASE_URL=http://host.docker.internal:1234

# OpenAI-compatible (any provider with OpenAI API)
OPENAI_LIKE_API_BASE_URL=
OPENAI_LIKE_API_KEY=

# AWS Bedrock — {"region":"us-east-1","accessKeyId":"...","secretAccessKey":"..."}
AWS_BEDROCK_CONFIG=

# ============================================================
# Optional Integrations (Git, Deployment, Database)
# ============================================================

# GitHub (for clone/push repos)
VITE_GITHUB_ACCESS_TOKEN=
VITE_GITHUB_TOKEN_TYPE=classic

# GitLab
VITE_GITLAB_ACCESS_TOKEN=
VITE_GITLAB_URL=https://gitlab.com
VITE_GITLAB_TOKEN_TYPE=personal-access-token

# Vercel
VITE_VERCEL_ACCESS_TOKEN=

# Netlify
VITE_NETLIFY_ACCESS_TOKEN=

# Supabase
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_SUPABASE_ACCESS_TOKEN=
